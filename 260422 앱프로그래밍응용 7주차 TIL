```bash
# 원격 MCP
claude mcp add --transport http notion 
https://mcp.notion.com/mcp


# 로컬 MCP (윈도우 cmd)
claude mcp add sequential-thinking -s 
local -- cmd /c npx -y 
@modelcontextprotocol/
server-sequential-thinking@latest


# 파워셸: cmd /c 제거
